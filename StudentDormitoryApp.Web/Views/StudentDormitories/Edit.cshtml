@model StudentDormitoryApp.Domain.DomainModels.StudentDormitory

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>StudentDormitory</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Photo" class="control-label"></label>
                <input asp-for="Photo" class="form-control" />
                <span asp-validation-for="Photo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Address" class="control-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RoomCount" class="control-label"></label>
                <input asp-for="RoomCount" class="form-control" />
                <span asp-validation-for="RoomCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BedCount" class="control-label"></label>
                <input asp-for="BedCount" class="form-control" />
                <span asp-validation-for="BedCount" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="HasReadingRoom" /> @Html.DisplayNameFor(model => model.HasReadingRoom)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="HasCafeteria" /> @Html.DisplayNameFor(model => model.HasCafeteria)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="RentPerMonth" class="control-label"></label>
                <input asp-for="RentPerMonth" class="form-control" />
                <span asp-validation-for="RentPerMonth" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FirstMonthRent" class="control-label"></label>
                <input asp-for="FirstMonthRent" class="form-control" />
                <span asp-validation-for="FirstMonthRent" class="text-danger"></span>
            </div>

            <label class="control-label">Documents</label>
            <input type="file" id="documentInput" name="Documents" multiple class="form-control" />

            <div id="previewContainer" class="mt-3"></div>

            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<script>
        document.getElementById("documentInput").addEventListener("change", function(event) {
        const previewContainer = document.getElementById("previewContainer");
        previewContainer.innerHTML = "";
        const files = event.target.files;

        for (let i = 0; i < files.length; i++) {
            const file = files[i];

            const fileItem = document.createElement("div");
            fileItem.textContent = "📄 " + file.name;
            fileItem.style.margin = "5px 0";

            previewContainer.appendChild(fileItem);
        }
    });
</script>