@model StudentDormitoryApp.Domain.DomainModels.StudentDormitory

@{
    ViewData["Title"] = "Нов студентски дом";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="hero2">
	<div class="hero2-bg"></div>
	<div class="hero2-content">
<h3 class="page-heading">Додади студентски дом</h3>
<p class="page-subtitle">Внеси ги основните податоци за новиот студентски дом.</p>


<div class="form-card">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Име</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Photo" class="form-label">Слика (URL)</label>
            <input asp-for="Photo" class="form-control" placeholder="https://..." />
            <span asp-validation-for="Photo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Address" class="form-label">Адреса</label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-sm-6 mb-3">
                <label asp-for="RoomCount" class="form-label">Број на соби</label>
                <input asp-for="RoomCount" class="form-control" />
                <span asp-validation-for="RoomCount" class="text-danger"></span>
            </div>
            <div class="col-sm-6 mb-3">
                <label asp-for="BedCount" class="form-label">Број на легла</label>
                <input asp-for="BedCount" class="form-control" />
                <span asp-validation-for="BedCount" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-6 mb-3 form-check">
                <input class="form-check-input" asp-for="HasReadingRoom" />
                <label class="form-check-label" asp-for="HasReadingRoom">Читална</label>
            </div>
            <div class="col-sm-6 mb-3 form-check">
                <input class="form-check-input" asp-for="HasCafeteria" />
                <label class="form-check-label" asp-for="HasCafeteria">Трпезарија</label>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-6 mb-3">
                <label asp-for="RentPerMonth" class="form-label">Месечна станарина (ден.)</label>
                <input asp-for="RentPerMonth" class="form-control" />
                <span asp-validation-for="RentPerMonth" class="text-danger"></span>
            </div>
            <div class="col-sm-6 mb-3">
                <label asp-for="FirstMonthRent" class="form-label">Прва месечна станарина (ден.)</label>
                <input asp-for="FirstMonthRent" class="form-control" />
                <span asp-validation-for="FirstMonthRent" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Документи</label>
            <input type="file" id="documentInput" name="Documents" multiple class="form-control" />
            <div id="previewContainer" class="doc-preview-list"></div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-brand">Зачувај</button>
            <a asp-action="Index" class="back-link">← Назад кон листата</a>
        </div>
    </form>
</div>
</div> 
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script>
    document.getElementById("documentInput").addEventListener("change", function (event) {
        const previewContainer = document.getElementById("previewContainer");
        previewContainer.innerHTML = "";
        const files = event.target.files;

        for (let i = 0; i < files.length; i++) {
            const file = files[i];

            const fileItem = document.createElement("div");
            fileItem.className = "doc-preview-item";
            fileItem.textContent = "📄 " + file.name;

            previewContainer.appendChild(fileItem);
        }
    });
</script>
