@model StudentDormitoryApp.Domain.DomainModels.StudentDormitory

@{
    ViewData["Title"] = "Детали за студентски дом";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading">@Model.Name</h3>
<p class="page-subtitle">@Model.Address</p>

<div class="detail-card">
    <dl class="row">
        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.RoomCount)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.RoomCount)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.BedCount)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.BedCount)</dd>

        <dt class="col-sm-4">Читална</dt>
        <dd class="col-sm-8">@(Model.HasReadingRoom ? "Да" : "Не")</dd>

        <dt class="col-sm-4">Трпезарија</dt>
        <dd class="col-sm-8">@(Model.HasCafeteria ? "Да" : "Не")</dd>

        <dt class="col-sm-4">Месечна станарина</dt>
        <dd class="col-sm-8">@Model.RentPerMonth ден.</dd>

        <dt class="col-sm-4">Прва месечна станарина</dt>
        <dd class="col-sm-8">@Model.FirstMonthRent ден.</dd>
    </dl>

    <div class="mt-3">
        <p class="fw-semibold mb-1">Документи</p>
        @if (Model.Documents != null && Model.Documents.Any())
        {
            <ul class="list-unstyled">
                @foreach (var doc in Model.Documents)
                {
                    <li>
                        <a href="@doc.FilePath" download="@doc.Name">
                            📄 @(doc.Name ?? System.IO.Path.GetFileName(doc.FilePath))
                        </a>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">Не се потребни документи при вселување</p>
        }
    </div>

    <div class="action-row">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Измени</a>
        <a asp-controller="Rooms" asp-action="Index" asp-route-id="@Model.Id" class="btn btn-brand">Погледни соби</a>
        <a asp-action="Index" class="back-link">← Назад кон листата</a>
    </div>
</div>
