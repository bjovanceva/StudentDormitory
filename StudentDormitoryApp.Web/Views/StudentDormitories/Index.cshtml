@model IEnumerable<StudentDormitoryApp.Domain.DomainModels.StudentDormitory>

@{
    ViewData["Title"] = "Студентски домови";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center mb-5 mt-3">
    <h1 class="page-heading">Студентски домови</h1>
    <p class="page-subtitle">Избегни ред на чекање. Всели се брзо, лесно и едноставно.</p>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="dorm-card">
                <a asp-action="Index" asp-controller="Rooms" asp-route-id="@item.Id">
                    @if (!string.IsNullOrEmpty(item.Photo))
                    {
                        <img src="@item.Photo" alt="@item.Name" />
                    }
                    <div class="dorm-card-body">
                        <h5>@item.Name</h5>
                        <p class="dorm-meta"><b>Адреса:</b> @item.Address</p>
                        <p class="dorm-meta"><b>Соби:</b> @item.RoomCount &nbsp;·&nbsp; <b>Легла:</b> @item.BedCount</p>
                        <p class="dorm-meta"><b>Месечна станарина:</b> @item.RentPerMonth ден.</p>

                        <div class="d-flex gap-2 flex-wrap mt-2">
                            <span class="pill @(item.HasReadingRoom ? "pill-on" : "pill-off")">
                                @(item.HasReadingRoom ? "📚 Читална" : "— Без читална")
                            </span>
                            <span class="pill @(item.HasCafeteria ? "pill-on" : "pill-off")">
                                @(item.HasCafeteria ? "🍽️ Трпезарија" : "— Без трпезарија")
                            </span>
                        </div>
                    </div>
                </a>

                <div class="d-flex gap-2 justify-content-center flex-wrap p-3 pt-0">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Детали</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Измени</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Избриши</a>
                        <a asp-action="Create" asp-controller="Rooms" asp-route-id="@item.Id" class="btn btn-sm btn-brand">+ Соба</a>
                    }
                </div>
            </div>
        </div>
    }
</div>