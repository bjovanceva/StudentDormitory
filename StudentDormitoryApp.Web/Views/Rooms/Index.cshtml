@model IEnumerable<StudentDormitoryApp.Domain.DomainModels.Room>

@{
    ViewData["Title"] = "Преглед на соби";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading">Преглед на соби</h3>
<p class="page-subtitle">Кликни на соба за детали и аплицирање.</p>

<div class="room-legend">
    <span><span class="legend-dot" style="background:#198754"></span> Слободна</span>
    <span><span class="legend-dot" style="background:#f5c518"></span> Делумно зафатена</span>
    <span><span class="legend-dot" style="background:#dc3545"></span> Целосно зафатена</span>
</div>

<div class="room-grid">
    @foreach (var room in Model)
    {
        string color;
        bool isFull = room.OccupiedBeds >= room.BedCount;

        if (room.OccupiedBeds == 0)
        {
            color = "#198754";
        }
        else if (isFull)
        {
            color = "#dc3545";
        }
        else
        {
            color = "#f5c518";
        }

        if (isFull)
        {
            <span class="room-card room-card-disabled"
            title="@room.Name — нема слободни легла"
            style="background-color:@color">
                @room.Name
            </span>
        }

        else
        {
             <a asp-action="Details" asp-route-id="@room.Id"
               class="room-card"
               style="background-color:@color">
                @room.Name
            </a>   
        }
        
    }
</div>