@model StudentDormitoryApp.Domain.DomainModels.Room

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
    

    .room-details-wrapper {
        font-family: 'DM Sans', sans-serif;
        max-width: 960px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .room-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 32px;
        border-bottom: 2px solid #1a1a1a;
        padding-bottom: 16px;
    }

        .room-header h1 {
            font-family: 'DM Serif Display', serif;
            font-size: 2.6rem;
            margin: 0;
            color: #1a1a1a;
        }

    .dorm-badge {
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: #1a1a1a;
        color: #fff;
        padding: 6px 14px;
        border-radius: 2px;
    }

    /* Two column layout */
    .room-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: start;
    }

    /* Info list */
    .info-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid #e8e8e8;
        border-radius: 8px;
        overflow: hidden;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 20px;
        border-bottom: 1px solid #f0f0f0;
        background: #fff;
    }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-row:nth-child(even) {
            background: #fafafa;
        }

    .info-label {
        font-size: 0.78rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
    }

    .info-value {
        font-size: 0.95rem;
        font-weight: 400;
        color: #1a1a1a;
        text-align: right;
    }

    .bool-true {
        color: #1a7a4a;
        font-weight: 500;
    }

    .bool-false {
        color: #bbb;
    }

    .beds-value {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 5px;
    }

    .beds-bar-track {
        width: 100px;
        height: 5px;
        background: #e0e0e0;
        border-radius: 10px;
        overflow: hidden;
    }

    .beds-bar-fill {
        height: 100%;
        background: #1a1a1a;
        border-radius: 10px;
    }

    /* Image stack */
    .image-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .room-image {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e8e8e8;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: block;
    }

        .room-image:hover {
            transform: scale(1.01);
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        }

    .no-images {
        color: #bbb;
        font-size: 0.9rem;
        padding: 20px;
        text-align: center;
        border: 1px dashed #ddd;
        border-radius: 8px;
    }

    /* Actions */
    .action-bar {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-top: 32px;
        padding-top: 20px;
        border-top: 1px solid #eee;
    }

    .btn-action {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 10px 22px;
        border-radius: 4px;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: all 0.15s ease;
        border: 1.5px solid transparent;
    }

    .btn-outline-dark {
        background: transparent;
        color: #1a1a1a;
        border-color: #ccc;
    }

        .btn-outline-dark:hover {
            border-color: #1a1a1a;
        }

    .btn-apply {
        background: #1a7a4a;
        color: #fff;
        border-color: #1a7a4a;
        margin-left: auto;
    }

        .btn-apply:hover {
            background: #155f39;
            color: #fff;
        }

    @@media (max-width: 640px) {
        .room-body {
            grid-template-columns: 1fr;
        }

        .room-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
    }
</style>

<div class="room-details-wrapper">

    <div class="room-header">
        <h1>@Html.DisplayFor(model => model.Name)</h1>
        <span class="dorm-badge">@Html.DisplayFor(model => model.StudentDormitory.Name)</span>
    </div>

    <div class="room-body">

        <div class="info-list">
            <div class="info-row">
                <span class="info-label">Зграда</span>
                <span class="info-value">@Html.DisplayFor(m => m.BuildingSection)</span>
            </div>
            <div class="info-row">
                <span class="info-label">Ориентација</span>
                <span class="info-value">@Html.DisplayFor(m => m.Orientation)</span>
            </div>
            <div class="info-row">
                <span class="info-label">Дуплекс</span>
                <span class="info-value @(Model.IsDuplex ? "bool-true" : "bool-false")">
                    @(Model.IsDuplex ? "✓ Yes" : "✗ No")
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">Сопствена бања</span>
                <span class="info-value @(Model.HasPrivateBathroom ? "bool-true" : "bool-false")">
                    @(Model.HasPrivateBathroom ? "✓ Yes" : "✗ No")
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">Сопствена кујна</span>
                <span class="info-value @(Model.HasKitchen ? "bool-true" : "bool-false")">
                    @(Model.HasKitchen ? "✓ Yes" : "✗ No")
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">Број на кревети</span>
                <span class="info-value">@Html.DisplayFor(m => m.BedCount)</span>
            </div>
            <div class="info-row">
                <span class="info-label">Зафатени легла</span>
                <div class="info-value beds-value">
                    <span>@Model.OccupiedBeds / @Model.BedCount</span>
                    <div class="beds-bar-track">
                        <div class="beds-bar-fill" style="width: @(Model.BedCount > 0 ? (Model.OccupiedBeds * 100 / Model.BedCount) : 0)%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="image-stack">
            @if (ViewBag.RoomImages != null && ViewBag.RoomImages.Count > 0)
            {
                @foreach (var img in ViewBag.RoomImages)
                {
                    <img src="@img.ImageUrl" class="room-image" />
                }
            }
            else
            {
                <div class="no-images">No images available</div>
            }
        </div>

    </div>

    <div class="action-bar">
        <a asp-action="Index" class="btn-action btn-outline-dark">← Назад</a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-action btn-outline-dark">Измени</a>
        <a class="btn-action btn-apply" asp-controller="Applications" asp-route-roomId="@Model?.Id" asp-action="Create">Аплицирај →</a>
    </div>

</div>
