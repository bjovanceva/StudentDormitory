@using Microsoft.AspNetCore.Identity
@using StudentDormitoryApp.Domain.Identity
@inject SignInManager<StudentDormitoryAppUser> SignInManager
@inject UserManager<StudentDormitoryAppUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="d-flex align-items-center gap-2">
        <a class="user-chip" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            👤 @User.Identity?.Name
        </a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-sm btn-outline-secondary">Одјави се</button>
        </form>
    </div>
}
else
{
    <a class="btn btn-sm btn-brand" asp-area="Identity" asp-page="/Account/Login">Најави се</a>
}