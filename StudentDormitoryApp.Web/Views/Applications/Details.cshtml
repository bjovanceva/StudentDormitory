@model StudentDormitoryApp.Domain.DomainModels.Application

@{
    ViewData["Title"] = "Детали за апликација";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    bool isAvailable = TempData["IsAvailable"] != null
        && (bool)TempData["IsAvailable"];
}

<h3 class="page-heading">Детали за апликација</h3>

<div class="detail-card">
    <dl class="row">
        <dt class="col-sm-3">Статус</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

        <dt class="col-sm-3">Коментар</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Comment)</dd>

        <dt class="col-sm-3">Дата на апликација</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ApplicationDate)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Room)</dt>
        <dd class="col-sm-9 d-flex align-items-center gap-2">
            @Html.DisplayFor(model => model.Room.Name)
            <span class="badge @(isAvailable ? "bg-success" : "bg-danger")">
                @(isAvailable ? "Собата е достапна" : "Собата не е достапна")
            </span>
        </dd>

        <dt class="col-sm-3">Студент</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.StudentDormitoryAppUserId)</dd>
    </dl>

    <p class="fw-semibold mb-1">Документи</p>
    @if (Model.Documents != null && Model.Documents.Any())
    {
        <ul class="list-unstyled">
            @foreach (var doc in Model.Documents)
            {
                <li>
                    <a href="@doc.FilePath" download="@doc.Name">
                        📄 @(doc.Name ?? System.IO.Path.GetFileName(doc.FilePath))
                    </a>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">Нема прикачени документи</p>
    }

    <hr />

    <form asp-action="HandleApplication" method="post">
        <input type="hidden" name="id" value="@Model?.Id" />

        <div class="mb-3">
            <label asp-for="Comment" class="form-label">Коментар</label>
            <input asp-for="Comment" class="form-control" />
            <span asp-validation-for="Comment" class="text-danger"></span>
        </div>

        <div class="action-row">
            <button type="submit" name="action" value="approve" class="btn btn-success">Прифати</button>
            <button type="submit" name="action" value="reject" class="btn btn-danger">Одбиј</button>
            <a asp-action="Index" class="back-link">← Назад кон листата</a>
        </div>
    </form>
</div>
