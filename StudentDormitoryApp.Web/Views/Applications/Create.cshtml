@model StudentDormitoryApp.Domain.DomainModels.Application

@{
    ViewData["Title"] = "Апликација";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading">Аплицирај за соба</h3>
<p class="page-subtitle">@ViewBag.StudentDormitoryName — соба @ViewBag.RoomName</p>

<div class="form-card">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="RoomId" value="@ViewBag.RoomId" />
        <input type="hidden" asp-for="StudentDormitoryAppUserId" value="@ViewBag.UserId" />

        <div class="mb-3">
            <label class="form-label">Соба</label>
            <input disabled class="form-control" value="@ViewBag.RoomName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Студентски дом</label>
            <input disabled class="form-control" value="@ViewBag.StudentDormitoryName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Е-маил адреса</label>
            <input disabled value="@ViewBag.UserEmail" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Comment" class="form-label">Коментар (по желба)</label>
            <input asp-for="Comment" class="form-control" />
            <span asp-validation-for="Comment" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Документи</label>
            <input type="file" id="documentInput" name="Documents" multiple class="form-control" />
            <div id="previewContainer" class="doc-preview-list"></div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-brand">Плати и аплицирај</button>
            <a asp-controller="Rooms" asp-action="Details" asp-route-id="@ViewBag.RoomId" class="back-link">← Назад кон собата</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script>
    document.getElementById("documentInput").addEventListener("change", function (event) {
        const previewContainer = document.getElementById("previewContainer");
        previewContainer.innerHTML = "";
        const files = event.target.files;

        for (let i = 0; i < files.length; i++) {
            const file = files[i];

            const fileItem = document.createElement("div");
            fileItem.className = "doc-preview-item";
            fileItem.textContent = "📄 " + file.name;

            previewContainer.appendChild(fileItem);
        }
    });
</script>
