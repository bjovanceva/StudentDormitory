@model StudentDormitoryApp.Domain.DomainModels.Document

@{
    ViewData["Title"] = "Измени документ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading">Измени документ</h3>
<p class="page-subtitle">@Model.Name</p>

<div class="form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Име на документ</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FilePath" class="form-label">Патека до датотека</label>
            <input asp-for="FilePath" class="form-control" />
            <span asp-validation-for="FilePath" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="StudentDormitoryId" class="form-label">Студентски дом</label>
            <select asp-for="StudentDormitoryId" class="form-select" asp-items="ViewBag.StudentDormitoryId"></select>
            <span asp-validation-for="StudentDormitoryId" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-brand">Зачувај промени</button>
            <a asp-action="Index" class="back-link">← Назад кон листата</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
