@model StudentDormitoryApp.Domain.DomainModels.Document

@{
    ViewData["Title"] = "Избриши документ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading text-danger">Избриши документ</h3>
<p class="page-subtitle">Дали сте сигурни дека сакате да го избришете овој документ? Ова дејство не може да се врати.</p>

<div class="detail-card">
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FilePath)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.FilePath)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.StudentDormitory)</dt>
        <dd class="col-sm-9">@(Model.StudentDormitory?.Name ?? "—")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="action-row">
            <input type="submit" value="Избриши" class="btn btn-danger" />
            <a asp-action="Index" class="back-link">← Назад кон листата</a>
        </div>
    </form>
</div>
