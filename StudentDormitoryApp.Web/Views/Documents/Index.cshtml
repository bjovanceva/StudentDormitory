@model IEnumerable<StudentDormitoryApp.Domain.DomainModels.Document>

@{
    ViewData["Title"] = "Документи";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="page-heading mb-0">Документи</h3>
        <p class="page-subtitle mb-0">Документи поврзани со студентските домови</p>
    </div>
    <a asp-action="Create" class="btn btn-brand"><i class="bi bi-plus-lg"></i> Нов документ</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-file-earmark-text"></i>
        <p class="mb-0">Сè уште нема прикачени документи.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.FilePath)</th>
                    <th>@Html.DisplayNameFor(model => model.StudentDormitory)</th>
                    <th class="text-end">Дејства</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td class="text-truncate" style="max-width:260px;">
                            <a href="@item.FilePath" target="_blank" rel="noopener">
                                <i class="bi bi-paperclip"></i> @Html.DisplayFor(modelItem => item.FilePath)
                            </a>
                        </td>
                        <td>@(item.StudentDormitory?.Name ?? "—")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Детали</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Измени</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Избриши</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
