@model StudentDormitoryApp.Domain.DomainModels.RoomImage

@{
    ViewData["Title"] = "Нова слика";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading">Додади слика за соба</h3>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="ImageUrl" class="form-label">Слика (URL)</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="/images/soba1.jpg" />
            <span asp-validation-for="ImageUrl" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RoomId" class="form-label">Соба</label>
            <select asp-for="RoomId" class="form-select" asp-items="ViewBag.RoomId"></select>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-brand">Зачувај</button>
            <a asp-action="Index" class="back-link">← Назад кон листата</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
