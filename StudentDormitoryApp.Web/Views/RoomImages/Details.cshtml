@model StudentDormitoryApp.Domain.DomainModels.RoomImage

@{
    ViewData["Title"] = "Детали за слика";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading">Детали за слика</h3>

<div class="detail-card">
    <img src="@Model.ImageUrl" alt="@Model.Room?.Name" class="img-fluid rounded mb-3" style="max-height:260px;object-fit:cover;" />

    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ImageUrl)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ImageUrl)</dd>

        <dt class="col-sm-3">Соба</dt>
        <dd class="col-sm-9">@Model.Room?.Name</dd>
    </dl>

    <div class="action-row">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-secondary">Измени</a>
        <a asp-action="Index" class="back-link">← Назад кон листата</a>
    </div>
</div>
