@model StudentDormitoryApp.Domain.DomainModels.RoomImage

@{
    ViewData["Title"] = "Избриши слика";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3 class="page-heading text-danger">Избриши слика</h3>
<p class="page-subtitle">Дали сте сигурни дека сакате да ја избришете оваа слика?</p>

<div class="detail-card">
    <img src="@Model.ImageUrl" alt="@Model.Room?.Name" class="img-fluid rounded mb-3" style="max-height:220px;object-fit:cover;" />

    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ImageUrl)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ImageUrl)</dd>

        <dt class="col-sm-3">Соба</dt>
        <dd class="col-sm-9">@Model.Room?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="action-row">
            <input type="submit" value="Избриши" class="btn btn-danger" />
            <a asp-action="Index" class="back-link">← Назад кон листата</a>
        </div>
    </form>
</div>
